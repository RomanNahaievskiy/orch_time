# Відповідає за приклад локальних налаштувань: порт сервера, доступ до MySQL та ідентифікатори Google Sheets.
PORT=3000
NODE_ENV=development

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=orch_user
MYSQL_PASSWORD=orch_password
MYSQL_DATABASE=orch_time
MYSQL_CONNECTION_LIMIT=10

SHIFT_OVERTIME_HOURS=17

GOOGLE_EMPLOYEES_SHEET_ID=
GOOGLE_EMPLOYEES_SHEET_RANGE=Аркуш1!A:E
GOOGLE_WORK_LOG_SHEET_ID=
GOOGLE_WORK_LOG_SHEET_RANGE=Аркуш1!A:H
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
